rules_version = '2';

// Regole Storage Firebase — romagnago-app
// Deploy: firebase deploy --only storage (dopo firebase init storage)
service firebase.storage {
  match /b/{bucket}/o {
    // Contenuti statici app (JSON): lettura pubblica, scrittura solo da Admin SDK / CI.
    match /start_content/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Foto profilo utente (come in altro_account_settings.dart).
    match /profile_images/{userId}.jpg {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
